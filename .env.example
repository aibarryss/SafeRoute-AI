# OpenRouter API ключ (получить на https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-...

# Модель (по умолчанию: openrouter/owl-alpha)
# Другие варианты: google/gemini-2.5-flash, openai/gpt-4o, и т.д.
OPENROUTER_MODEL=openrouter/owl-alpha

# 2GIS API ключ (получить на https://dev.2gis.com/)
TWOGIS_API_KEY=...
